function addToCart(btn) {
  const cc = btn.closest(".cc");
  CART.add(cc.dataset.name, parseInt(cc.dataset.price));
  btn.textContent = "&#10003; Added"; btn.style.background = "var(--brass)";
  setTimeout(() => { btn.textContent = "+ Add"; btn.style.background = ""; }, 1800);
}

function handleOrderNow() {
  if (!currentUser) { openMo("moAuth","signup"); return; }
  fillMqMenu(); renderCart(); openMo("moOrder");
}

function fillMqMenu() {
  document.getElementById("mqMenu").innerHTML = MENU.map(m =>
    `<div class="mq-row">
      <div><div class="mq-rn">${m.name}</div><div class="mq-rp">&#8358;${m.price.toLocaleString()} &middot; ${m.cat}</div></div>
      <button class="mq-ra" onclick="CART.add(\`${m.name}\`,${m.price})">+ Add</button>
    </div>`
  ).join("");
