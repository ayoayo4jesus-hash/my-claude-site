   INTERSECTION OBSERVER
============================================= */
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add("vi"); });
}, {threshold:.07, rootMargin:"0px 0px -25px 0px"});

/* =============================================
   CURSOR
============================================= */
(function(){
  const d = document.getElementById("cDot"), r = document.getElementById("cRing");
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener("mousemove", e => { mx=e.clientX; my=e.clientY; d.style.left=mx+"px"; d.style.top=my+"px"; });
  (function lp(){ rx+=(mx-rx)*.11; ry+=(my-ry)*.11; r.style.left=rx+"px"; r.style.top=ry+"px"; requestAnimationFrame(lp); })();
  document.querySelectorAll("a,button,.cc,.rvc,.bk,.mq-row").forEach(el => {
    el.addEventListener("mouseenter", () => document.body.classList.add("ch"));
    el.addEventListener("mouseleave", () => document.body.classList.remove("ch"));
