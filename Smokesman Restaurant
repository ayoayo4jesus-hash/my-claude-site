   CART
============================================= */
const CART = {
  items: [],
  add(name, price) { this.items.push({id: Date.now()+Math.random(), name, price}); renderCart(); },
  rm(id) { this.items = this.items.filter(i => i.id !== id); renderCart(); },
  total() { return this.items.reduce((s,i) => s+i.price, 0); },
  clear() { this.items = []; renderCart(); }
};

const MENU = [
  {name:"Smokesman Special Suya",price:3500,cat:"Grill"},
  {name:"Whole Smoked Chicken",price:6500,cat:"Grill"},
  {name:"Grilled Catfish",price:5500,cat:"Grill"},
  {name:"Smoked Goat Ribs",price:7000,cat:"Grill"},
  {name:"Smoked Turkey Leg",price:4500,cat:"Grill"},
  {name:"Prime Rib-Eye Beef",price:8500,cat:"Grill"},
  {name:"Peppered Fried Plantain",price:800,cat:"Sides"},
  {name:"Smokesman Peppersoup",price:2000,cat:"Sides"},
  {name:"Pasta & Smoky Tomato",price:2500,cat:"Sides"},
  {name:"Zobo Delight",price:500,cat:"Drinks"},
  {name:"Cold Selection",price:300,cat:"Drinks"}
];

function renderCart() {
  const rows = document.getElementById("cartRows");
  const empty = document.getElementById("cartEmptyMsg");
  const tot = document.getElementById("cartTot");
  const btn = document.getElementById("chkBtn");
  if (!rows) return;
  if (!CART.items.length) {
    rows.innerHTML = ""; empty.style.display = ""; tot.style.display = "none"; btn.style.display = "none"; return;
  }
  empty.style.display = "none"; tot.style.display = "flex"; btn.style.display = "";
  rows.innerHTML = CART.items.map(i =>
    `<div class="cr"><span class="cr-n">${i.name}</span>
    <div class="cr-r"><span class="cr-p">&#8358;${i.price.toLocaleString()}</span>
