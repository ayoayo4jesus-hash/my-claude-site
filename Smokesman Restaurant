  for(let i=0;i<N;i++){
    pos[i*3]=(Math.random()-.5)*24; pos[i*3+1]=Math.random()*-20; pos[i*3+2]=(Math.random()-.5)*6;
    const t=Math.random(); col[i*3]=.65+t*.35; col[i*3+1]=.14+t*.46; col[i*3+2]=0;
    vel.push({vx:(Math.random()-.5)*.012, vy:.013+Math.random()*.03, w:Math.random()*Math.PI*2, ws:.011+Math.random()*.022, wa:.002+Math.random()*.005});
  }
  geo.setAttribute("position",new THREE.BufferAttribute(pos,3));
  geo.setAttribute("color",new THREE.BufferAttribute(col,3));
  const mat=new THREE.PointsMaterial({size:.13,vertexColors:true,transparent:true,opacity:.9,blending:THREE.AdditiveBlending,depthWrite:false,sizeAttenuation:true});
  const pts=new THREE.Points(geo,mat); scene.add(pts);
  const G=55, g2=new THREE.BufferGeometry(), p2=new Float32Array(G*3), c2=new Float32Array(G*3), v2=[];
  for(let i=0;i<G;i++){
    p2[i*3]=(Math.random()-.5)*20; p2[i*3+1]=Math.random()*-20; p2[i*3+2]=(Math.random()-.5)*5;
    const t=Math.random(); c2[i*3]=.7+t*.3; c2[i*3+1]=.28+t*.35; c2[i*3+2]=0;
    v2.push({vx:(Math.random()-.5)*.008, vy:.009+Math.random()*.018, w:Math.random()*Math.PI*2, ws:.009+Math.random()*.016, wa:.003+Math.random()*.005});
  }
  g2.setAttribute("position",new THREE.BufferAttribute(p2,3));
  g2.setAttribute("color",new THREE.BufferAttribute(c2,3));
  const m2=new THREE.PointsMaterial({size:.46,vertexColors:true,transparent:true,opacity:.19,blending:THREE.AdditiveBlending,depthWrite:false,sizeAttenuation:true});
  scene.add(new THREE.Points(g2,m2));
  const clk=new THREE.Clock();
  (function tick(){
    requestAnimationFrame(tick); const t=clk.getElapsedTime();
    const pa=pts.geometry.attributes.position.array;
    for(let i=0;i<N;i++){ const v=vel[i]; v.w+=v.ws; pa[i*3]+=v.vx+Math.sin(v.w)*v.wa; pa[i*3+1]+=v.vy; if(pa[i*3+1]>12){pa[i*3]=(Math.random()-.5)*24;pa[i*3+1]=-16;pa[i*3+2]=(Math.random()-.5)*6;}}
    pts.geometry.attributes.position.needsUpdate=true;
    const ga=g2.attributes.position.array;
    for(let i=0;i<G;i++){ const v=v2[i]; v.w+=v.ws; ga[i*3]+=v.vx+Math.sin(v.w)*v.wa; ga[i*3+1]+=v.vy; if(ga[i*3+1]>12){ga[i*3]=(Math.random()-.5)*20;ga[i*3+1]=-16;ga[i*3+2]=(Math.random()-.5)*5;}}
    g2.attributes.position.needsUpdate=true;
    cam.position.x=Math.sin(t*.07)*.3; cam.position.y=Math.sin(t*.055)*.18;
    ren.render(scene,cam);
  })();
  window.addEventListener("scroll", () => { cvs.style.transform=`translateY(${scrollY*.28}px)`; }, {passive:true});
  window.addEventListener("resize", () => { const nW=hero.clientWidth,nH=hero.clientHeight; cam.aspect=nW/nH; cam.updateProjectionMatrix(); ren.setSize(nW,nH); }, {passive:true});
})();

