  document.getElementById("cfMsg").innerHTML = method === "paypal"
    ? `Your PayPal payment of &#8358;${total.toLocaleString()} was initiated. We are firing up the grill! Call 0815 561 5166 for updates.`
    : `Your bank transfer of &#8358;${total.toLocaleString()} is received. Once payment clears, we will get started immediately.`;
  document.getElementById("cfRef").textContent = ref;
  openMo("moConfirm");
}

/* =============================================
   MODAL SYSTEM
============================================= */
function openMo(id, tab) {
  document.querySelectorAll(".mo").forEach(m => m.classList.remove("open"));
  const m = document.getElementById(id);
  if (!m) return;
  m.classList.add("open");
  document.body.classList.add("locked");
  if (id === "moAuth" && tab) swAuth(tab);
  if (id === "moAccount") fillAccount();
  if (id === "moPayment") fillPayment();
}
function closeMo(id) {
  const m = document.getElementById(id);
  if (m) m.classList.remove("open");
  document.body.classList.remove("locked");
}
document.querySelectorAll(".mo").forEach(m => {
  m.addEventListener("click", e => { if (e.target === m) { m.classList.remove("open"); document.body.classList.remove("locked"); }});
});

