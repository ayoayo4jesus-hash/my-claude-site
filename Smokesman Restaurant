   TOAST
============================================= */
function toast(msg) {
  const t = document.getElementById("toast");
  t.innerHTML = msg; t.classList.add("show");
  clearTimeout(t._t); t._t = setTimeout(() => t.classList.remove("show"), 3500);
}

