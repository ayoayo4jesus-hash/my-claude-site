(function(){
  const foods=["&#127831;","&#127830;","&#129385;","&#127837;","&#127831;","&#128004;","&#129385;","&#127830;","&#127831;","&#127837;","&#127798;","&#128293;","&#127831;","&#127830;","&#129385;","&#127837;","&#128016;","&#129373;"];
  const c=document.getElementById("foodBg");
