setTimeout(() => {
  document.getElementById("pre").classList.add("out");
  document.getElementById("hT").querySelectorAll(".split-line").forEach(s => s.classList.add("vi"));
  document.querySelectorAll(".rv,.split-line,.ms").forEach(el => obs.observe(el));
}, 2800);

