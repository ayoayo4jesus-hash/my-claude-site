function goToPayment() { if (!CART.items.length) return; closeMo("moOrder"); openMo("moPayment"); }

/* =============================================
   PAYMENT
============================================= */
function fillPayment() {
  const total = CART.total(), items = CART.items;
  document.getElementById("pSum").innerHTML =
    items.slice(0,4).map(i => `<div class="psr"><span class="psr-l">${i.name}</span><span class="psr-v">&#8358;${i.price.toLocaleString()}</span></div>`).join("") +
