<script>
/* =============================================
   FIREBASE CONFIG
   Replace the values below with your real
   Firebase project config from the console
============================================= */
const firebaseConfig = {
  apiKey: "AIzaSyDK7wr0-vMual69DssqwPlQ4wV59dnPfTc",
  authDomain: "PASTE-YOUR-PROJECT-ID.firebaseapp.com",
  projectId: "smokesman-canteen",
  storageBucket: "smokesman-canteen.firebasestorage.app.appspot.com",
  messagingSenderId: "705778808939",
  appId: "1:705778808939:web:6a437fcba9243f8b6a592e"
};

/* =============================================
   FIREBASE INIT (only runs if config is real)
============================================= */
const FB_READY = !firebaseConfig.apiKey.includes("PASTE");
let auth = null, db = null;

if (FB_READY) {
  firebase.initializeApp(firebaseConfig);
  auth = firebase.auth();
  db = firebase.firestore();
  document.getElementById("setupBanner").classList.remove("show");
  document.getElementById("nav").classList.remove("bumped");

  auth.onAuthStateChanged(async user => {
    if (user) {
      await loadUserProfile(user.uid);
    } else {
      currentUser = null;
      updateNav();
    }
  });
} else {
  document.getElementById("setupBanner").classList.add("show");
  document.getElementById("nav").classList.add("bumped");
}

/* =============================================
   CURRENT USER STATE
============================================= */
let currentUser = null;

/* =============================================
   AUTH FUNCTIONS
============================================= */
function swAuth(tab) {
  const lg = tab === "login";
  document.getElementById("tLogin").classList.toggle("on", lg);
  document.getElementById("tSignup").classList.toggle("on", !lg);
  document.getElementById("fLogin").style.display = lg ? "" : "none";
  document.getElementById("fSignup").style.display = lg ? "none" : "";
  document.getElementById("authT").innerHTML = lg ? "Welcome <em>Back</em>" : "Join <em>Us</em>";
  document.getElementById("authS").textContent = lg
    ? "Sign in to order and manage your profile."
    : "Create your free account to order online.";
  ["lErr","sNmE","sEmE","sPwE"].forEach(id => {
    const e = document.getElementById(id); if(e) e.classList.remove("show");
  });
}

async function doLogin() {
  if (!FB_READY) { toast("&#9889; Please complete Firebase setup first"); openMo("moSetup"); return; }
  const email = document.getElementById("lEm").value.trim();
  const pwd = document.getElementById("lPw").value;
  const errEl = document.getElementById("lErr");
  const btn = document.getElementById("loginBtn");
  errEl.classList.remove("show");
  btn.disabled = true;
  btn.innerHTML = "<span class=\"spin\"></span>Signing In...";
  try {
    await auth.signInWithEmailAndPassword(email, pwd);
    closeMo("moAuth");
    toast("Welcome back! &#128293;");
  } catch(e) {
    errEl.classList.add("show");
  } finally {
    btn.disabled = false;
    btn.innerHTML = "Sign In to My Account";
  }
}

async function doSignup() {
  if (!FB_READY) { toast("&#9889; Please complete Firebase setup first"); openMo("moSetup"); return; }
  const name = document.getElementById("sNm").value.trim();
  const email = document.getElementById("sEm").value.trim();
  const pwd = document.getElementById("sPw").value;
  const btn = document.getElementById("signupBtn");
  ["sNmE","sEmE","sPwE"].forEach(id => document.getElementById(id).classList.remove("show"));
  if (!name) { document.getElementById("sNmE").classList.add("show"); return; }
  if (pwd.length < 6) { document.getElementById("sPwE").classList.add("show"); return; }
  btn.disabled = true;
  btn.innerHTML = "<span class=\"spin\"></span>Creating Account...";
  try {
    const cred = await auth.createUserWithEmailAndPassword(email, pwd);
    await db.collection("users").doc(cred.user.uid).set({
      name,
      email: email.toLowerCase(),
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      totalSpent: 0,
      orderCount: 0
    });
    closeMo("moAuth");
    toast("Welcome to Smokesman, " + name.split(" ")[0] + "! &#128293;");
  } catch(e) {
    if (e.code === "auth/email-already-in-use") {
      document.getElementById("sEmE").classList.add("show");
    } else {
      toast("Error: " + e.message);
    }
  } finally {
    btn.disabled = false;
    btn.innerHTML = "Create My Account";
  }
}

async function doLogout() {
  await auth.signOut();
  closeMo("moAccount");
  toast("Logged out. See you soon! &#128075;");
}

/* =============================================
   LOAD USER PROFILE FROM FIRESTORE
============================================= */
async function loadUserProfile(uid) {
  try {
    const doc = await db.collection("users").doc(uid).get();
    if (doc.exists) {
      currentUser = { uid, ...doc.data() };
    } else {
      currentUser = { uid, name: auth.currentUser.email, email: auth.currentUser.email, totalSpent: 0, orderCount: 0 };
    }
    updateNav();
  } catch(e) {
    currentUser = { uid, name: "User", email: "", totalSpent: 0, orderCount: 0 };
    updateNav();
  }
}

/* =============================================
   ACCOUNT DASHBOARD
============================================= */
async function fillAccount() {
  if (!currentUser) return;
  document.getElementById("acAv").textContent = (currentUser.name || "U").charAt(0).toUpperCase();
  document.getElementById("acNm").textContent = currentUser.name || "User";
  document.getElementById("acEm").textContent = currentUser.email || "";
  const created = currentUser.createdAt;
  let createdStr = "Today";
  if (created && created.toDate) {
    createdStr = created.toDate().toLocaleDateString("en-GB", {day:"numeric",month:"long",year:"numeric"});
  }
  document.getElementById("acSince").textContent = "Member since " + createdStr;
  document.getElementById("acOC").textContent = currentUser.orderCount || 0;
  document.getElementById("acSp").textContent = "&#8358;" + (currentUser.totalSpent || 0).toLocaleString();
  const ol = document.getElementById("acOL");
  ol.innerHTML = "<div class=\"ord-empty\"><span class=\"spin\"></span> Loading orders...</div>";
  try {
    const snap = await db.collection("users").doc(currentUser.uid).collection("orders")
      .orderBy("createdAt", "desc").limit(5).get();
    if (snap.empty) {
      ol.innerHTML = "<div class=\"ord-empty\">No orders yet. Start by adding items to your cart.</div>";
    } else {
      ol.innerHTML = snap.docs.map(d => {
        const o = d.data();
        return `<div class="ord-item">
          <div><div class="oi-n">${(o.items||[]).slice(0,2).join(", ")}${(o.items||[]).length>2?"...":""}</div>
          <div class="oi-d">${o.date||""} &middot; ${o.method||""} &middot; ${o.ref||""}</div></div>
          <div class="oi-p">&#8358;${(o.total||0).toLocaleString()}</div></div>`;
      }).join("");
    }
  } catch(e) {
    ol.innerHTML = "<div class=\"ord-empty\">Could not load orders.</div>";
  }
}

function openDelConf() { closeMo("moAccount"); openMo("moDel"); }

async function doDelete() {
  if (!auth || !auth.currentUser) return;
  const btn = document.getElementById("delBtn");
  btn.disabled = true;
  btn.innerHTML = "<span class=\"spin\"></span>Deleting...";
  try {
    const uid = auth.currentUser.uid;
    await db.collection("users").doc(uid).delete();
    await auth.currentUser.delete();
    closeMo("moDel");
    updateNav();
    toast("Account permanently deleted. Goodbye. &#128075;");
  } catch(e) {
    if (e.code === "auth/requires-recent-login") {
      toast("For security, please log out and log back in before deleting.");
      closeMo("moDel");
    } else {
      toast("Error deleting account: " + e.message);
    }
  } finally {
    btn.disabled = false;
    btn.innerHTML = "Yes, Delete Forever";
  }
}

/* =============================================
   SAVE ORDER TO FIRESTORE
============================================= */
async function saveOrderToFirestore(items, total, method) {
  if (!currentUser || !db) return "SMK-" + Math.floor(Math.random()*90000+10000);
  const ref = "SMK-" + Math.floor(Math.random()*90000+10000);
  try {
    await db.collection("users").doc(currentUser.uid).collection("orders").add({
      ref,
      items: items.map(i => i.name),
      total,
      method,
      date: new Date().toLocaleDateString("en-GB"),
      createdAt: firebase.firestore.FieldValue.serverTimestamp()
    });
    await db.collection("users").doc(currentUser.uid).update({
      totalSpent: firebase.firestore.FieldValue.increment(total),
      orderCount: firebase.firestore.FieldValue.increment(1)
    });
    currentUser.totalSpent = (currentUser.totalSpent || 0) + total;
    currentUser.orderCount = (currentUser.orderCount || 0) + 1;
  } catch(e) { console.error("Order save error:", e); }
  return ref;
}

/* =============================================
   NAV UPDATE
============================================= */
function updateNav() {
  const u = currentUser;
  document.getElementById("navAuth").style.display = u ? "none" : "flex";
  document.getElementById("navUser").style.display = u ? "flex" : "none";
  if (u) {
    document.getElementById("nAv").textContent = (u.name || "U").charAt(0).toUpperCase();
    document.getElementById("nUn").textContent = (u.name || "User").split(" ")[0];
  }
}

