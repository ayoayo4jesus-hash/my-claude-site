============================================= */
document.querySelectorAll(".mag").forEach(b => {
  b.addEventListener("mousemove", e => { const r=b.getBoundingClientRect(); b.style.transform=`translate(${(e.clientX-r.left-r.width/2)*.28}px,${(e.clientY-r.top-r.height/2)*.28}px)`; b.style.transition="transform .08s"; });
  b.addEventListener("mouseleave", () => { b.style.transform=""; b.style.transition="transform .55s var(--ease)"; });
});

